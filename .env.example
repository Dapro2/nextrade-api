# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/nextrade

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CoinGecko (free tier — no key needed, or use pro)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# Binance (for live trading)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_BASE_URL=https://api.binance.com

# Email (SendGrid or SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_key
EMAIL_FROM=noreply@nextrade.com

# App
FRONTEND_URL=http://localhost:3000
ENCRYPTION_KEY=32_char_encryption_key_change_me

# ─── KUCOIN API (Backup Exchange) ────────────────────────────────────────────
# Get these from: https://www.kucoin.com/account/api
# Apply for affiliate: https://www.kucoin.com/affiliate-program
KUCOIN_API_KEY=your_kucoin_api_key_here
KUCOIN_SECRET_KEY=your_kucoin_secret_key_here
KUCOIN_PASSPHRASE=your_kucoin_passphrase_here
KUCOIN_BASE_URL=https://api.kucoin.com
